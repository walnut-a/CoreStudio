{
  "name": "image-board-desktop",
  "version": "1.1.12",
  "private": true,
  "license": "MIT",
  "description": "CoreStudio desktop image board",
  "bin": {
    "corestudio": "bin/corestudio.cjs"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "ensure:electron": "node scripts/ensure-electron.cjs",
    "check:dev-port": "node scripts/ensure-dev-port.cjs",
    "check:secrets": "node scripts/check-secrets.cjs",
    "dev:renderer": "vite --config vite.config.mts --host 127.0.0.1 --port 5174",
    "dev:electron": "yarn ensure:electron && wait-on tcp:5174 file:dist-electron/main.js file:dist-electron/preload.js && ELECTRON_RENDERER_URL=http://127.0.0.1:5174 electron dist-electron/main.js",
    "build:renderer": "vite build --config vite.config.mts",
    "build:electron": "esbuild electron/main.ts electron/preload.ts electron/agent/cliRuntime.ts --bundle --platform=node --format=cjs --outdir=dist-electron --external:electron --tsconfig=tsconfig.electron.json",
    "start": "yarn check:dev-port && concurrently -k -n ELECTRON,RENDERER -c green,cyan \"yarn build:electron && yarn dev:electron\" \"yarn dev:renderer\"",
    "build": "yarn build:renderer && yarn build:electron",
    "preview": "yarn ensure:electron && yarn build && electron dist-electron/main.js",
    "package:dir": "yarn build && yarn check:secrets --source --package-inputs && electron-builder --dir && yarn check:secrets --release",
    "notarize:release": "node scripts/notarize-release.cjs",
    "package:app": "yarn build && yarn check:secrets --source --package-inputs && electron-builder && yarn notarize:release && yarn check:secrets --release",
    "test": "cd ../.. && vitest apps/image-board-desktop"
  },
  "devDependencies": {
    "@excalidraw/common": "0.18.0",
    "@excalidraw/element": "0.18.0",
    "@excalidraw/excalidraw": "0.18.0",
    "@google/genai": "1.49.0",
    "@types/node": "^24.8.1",
    "concurrently": "9.2.1",
    "electron": "41.2.0",
    "electron-builder": "26.8.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "wait-on": "9.0.5"
  },
  "build": {
    "appId": "com.corestudio.desktop",
    "productName": "CoreStudio",
    "directories": {
      "output": "release"
    },
    "electronLanguages": [
      "en",
      "en-US",
      "zh_CN",
      "zh-CN",
      "zh_TW",
      "zh-TW"
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "bin/**/*"
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "identity": "junyan liu (CUP682RD2S)",
      "icon": "build/icon.icns"
    },
    "dmg": {
      "title": "CoreStudio ${version}",
      "backgroundColor": "#f5f5f5",
      "iconSize": 112,
      "iconTextSize": 14,
      "window": {
        "width": 640,
        "height": 420
      },
      "contents": [
        {
          "x": 180,
          "y": 210,
          "type": "file"
        },
        {
          "x": 460,
          "y": 210,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@assistant-ui/react": "0.14.24"
  }
}
